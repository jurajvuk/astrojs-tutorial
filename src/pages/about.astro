---
import BaseLayout from '../layouts/BaseLayout.astro';
const pageTitle = "About Us";

const identity = {
	firstName: "Juraj",
	country: "Croatia",
	occupation: "Electrical Engineer",
	hobbies: ["sim racing", "diy electronics", "3D printing"]
	};
const skills = ["Scada", "Automation", "C programming", "Javascript", "Embedded"];

const happy = true;
const finished = false;
const goal = 3;

const skillColor = "crimson";
const fontWeight = "bold";
const textCase = "capitalize";
---

<BaseLayout pageTitle={pageTitle}></BaseLayout>
	<p>Here are facts about me:</p>
	<ul>
		<li>My name is: {identity.firstName}.</li>
		<li>I live in {identity.country} as a {identity.occupation}.</li>
		{identity.hobbies.length >= 2 && 
			<li>Two of my hobbies are: {identity.hobbies[0]} and {identity.hobbies[1]}</li>
		}
	</ul>
	<p>My skills are:</p>
	<ul>
		{skills.map((skill) => <li class="skill">{skill}</li>)}
	</ul>

	{happy && <p>I am happy to be learning Astro!</p>}

	{finished && <p>I finished this tutorial!</p>}

	{goal === 3 ? <p>My goal is to finish in 3 days.</p> : <p>My goal is not 3 days.</p>}
</BaseLayout>
